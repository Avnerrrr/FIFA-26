nd","a":"Croatia","hs":4,"as":2,"hsc":"Kane 18' (pen), Kane 35', Bellingham 61', Rashford 78'","asc":"Baturina 25', Musa 41'","city":"Arlington","date":"Jun 17"},{"grp":"Group L","h":"Ghana","a":"Panama","hs":1,"as":0,"hsc":"Yirenkyi 90+4'","asc":"—","city":"Toronto","date":"Jun 17"},{"grp":"Group I","h":"France","a":"Senegal","hs":3,"as":1,"hsc":"Mbappé 66', Barcola 82', Mbappé 90+6'","asc":"Mbaye 90+5'","city":"East Rutherford","date":"Jun 16"},{"grp":"Group I","h":"Norway","a":"Iraq","hs":4,"as":1,"hsc":"Haaland 23', Haaland 51', Hussein 70' (og), Østigård 80'","asc":"Hussein 44'","city":"Foxborough","date":"Jun 16"},{"grp":"Group J","h":"Argentina","a":"Algeria","hs":3,"as":0,"hsc":"Messi 17', Messi 60', Messi 76'","asc":"—","city":"Kansas City","date":"Jun 16"}],"NEWS":[{"cat":"tournament","h":"Cape Verde's fairytale rolls on — first-ever World Cup goals deny Uruguay","s":"One of the smallest nations ever to reach a World Cup, Cape Verde followed their goalless hold of Spain by twice fighting back to draw 2-2 with Uruguay. Kevin Pina's 21st-minute free kick was the islanders' first goal at a World Cup, and two points leaves the debutants in genuine contention to reach the knockouts.","src":"ESPN / Al Jazeera / NBC News"},{"cat":"tournament","h":"Keeper Vozinha becomes the Cup's breakout star, Instagram following past 14 million","s":"Cape Verde's 40-year-old goalkeeper Josimar 'Vozinha' Dias has gone viral after his man-of-the-match heroics against Spain, with his following rocketing past 14 million. The tiny island nation's defensive masterclasses have captured the tournament's imagination.","src":"ESPN / Yahoo Sports"},{"cat":"tournament","h":"Iran say they played 'beautiful game in worst conditions' amid travel and entry restrictions","s":"Iran held Belgium to a goalless draw despite a red card, with coach Amir Ghalenoei's side again forced to enter the U.S. only the day before and leave the same night. Iran has lodged a formal complaint with FIFA over the same-night exits and lengthy hauls back across the border.","src":"ESPN / Al Jazeera / CBS"},{"cat":"tournament","h":"Mandatory hydration breaks unite players, coaches and fans — in frustration","s":"Fixed drinks breaks applied at all 104 matches regardless of conditions have drawn boos and criticism from coaches including France's Didier Deschamps, who says they split each half into 'almost four quarters.' Spain's Luis de la Fuente concedes they help in genuine heat but feel needless inside climate-controlled stadiums.","src":"Yahoo Sports / ESPN / Al Jazeera"},{"cat":"tournament","h":"Heat the looming co-favorite: scientists warn most matches risk performance-impairing conditions","s":"Climate analysis finds 97 of the 104 fixtures carry an elevated risk of performance-impairing heat, with Miami, Houston, Dallas, Mexico City and Guadalajara the hottest venues. Organizers have leaned on more evening kickoffs and the contentious mandatory hydration breaks to cope.","src":"Climate Central / Scientific American / Al Jazeera"}],"TOURN":[{"ic":"🏆","nm":"FIFA World Cup 2026","sub":"USA · Canada · Mexico","desc":"Group stage, Matchday 2 underway. 48 teams; Round of 32 begins Jun 28.","status":"LIVE","cls":"b-tournament"},{"ic":"🏟️","nm":"UEFA Champions League","sub":"Europe · club","desc":"2025–26 concluded in late May. New league phase returns September 2026.","status":"OFF-SEASON","cls":"b-sched"},{"flag":"Spain","nm":"La Liga","sub":"Spain · domestic","desc":"2025–26 wrapped up in May. 2026–27 kicks off in August.","status":"OFF-SEASON","cls":"b-sched"},{"flag":"Australia","nm":"A-League Men","sub":"Australia · domestic","desc":"Off-season. 2025–26 finished; new season later in 2026.","status":"OFF-SEASON","cls":"b-sched"}],"FIFA":[{"ic":"📋","nm":"Biggest World Cup yet","sub":"Format","desc":"48 teams in 12 groups; top two plus 8 best third-placed sides reach the new Round of 32.","src":"FIFA / CBS"},{"ic":"🏟️","nm":"Club World Cup expanded","sub":"Club football","desc":