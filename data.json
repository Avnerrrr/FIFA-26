  {
   "cat": "tournament",
   "h": "Iran ordered out of the U.S. within hours of every match, sparking FIFA complaint",
   "s": "Iran's team must enter the country only the day before each game and leave the same night, coach Amir Ghalenoei says, calling his side 'perhaps the most oppressed' at the Cup after a five-hour post-match haul back to Tijuana. Iran has lodged a formal complaint with FIFA over the restrictions.",
   "src": "ESPN / Al Jazeera / CBS / The Hill"
  },
  {
   "cat": "tournament",
   "h": "Cape Verde's 40-year-old keeper Vozinha becomes the Cup's breakout star",
   "s": "Josimar 'Vozinha' Dias made a string of saves to hold favorites Spain to a 0-0 draw on debutants Cape Verde's World Cup bow and was named Man of the Match. His Instagram following has rocketed past 5 million as the tiny island nation's defensive masterclass captures the tournament's imagination.",
   "src": "ESPN / Yahoo Sports / Al Jazeera"
  },
  {
   "cat": "tournament",
   "h": "Mandatory hydration breaks unite players, coaches and fans — in frustration",
   "s": "Fixed drinks breaks applied at all 104 matches regardless of conditions have drawn boos and criticism from coaches including France's Didier Deschamps, who says they split each half into 'almost four quarters.' Spain's Luis de la Fuente concedes they help in genuine heat but feel needless inside climate-controlled stadiums.",
   "src": "Yahoo Sports / ESPN / Al Jazeera"
  },
  {
   "cat": "tournament",
   "h": "Tunisia sack coach mid-tournament after 5-1 rout, hand reins to Hervé Renard",
   "s": "Sabri Lamouchi became the first coach officially dismissed during the 2026 finals, axed one game in following a 5-1 Group F humbling by Sweden amid reported dressing-room tension. Veteran Hervé Renard has been drafted in to steer Tunisia through the rest of the group stage.",
   "src": "ESPN / Fox Sports / Fox News"
  },
  {
   "cat": "tournament",
   "h": "Heat the looming co-favorite: scientists warn most matches risk performance-impairing conditions",
   "s": "Climate analysis finds 97 of the 104 fixtures carry an elevated risk of performance-impairing heat, with Miami, Houston, Dallas, Mexico City and Guadalajara the hottest venues. Organizers have leaned on more evening kickoffs and the contentious mandatory hydration breaks to cope.",
   "src": "Climate Central / Scientific American / Al Jazeera"
  }
 ],
