 "NEWS": [
  {
   "cat": "tournament",
   "h": "Curaçao make history as Eloy Room's 15 saves earn a first World Cup point",
   "s": "The smallest nation ever to reach a World Cup held Ecuador to a goalless draw in Kansas City, with 39-year-old keeper Eloy Room making 15 saves — the most by a goalkeeper in a finals match in decades. Ecuador's 15 efforts without scoring were the most in a World Cup game since 1966.",
   "src": "ESPN / Outlook India"
  },
  {
   "cat": "tournament",
   "h": "Almirón is first player ever red-carded under FIFA's mouth-covering rule",
   "s": "Paraguay's Miguel Almirón became the first man sent off under a new 2026 law banning players from covering their mouths to hide what they say, after an exchange with Türkiye's Mert Müldür. Paraguay still won 1-0 with ten men — and knocked Türkiye out.",
   "src": "ESPN / Fox Sports / Al Jazeera"
  },
  {
   "cat": "tournament",
   "h": "World Cup smashes its all-time daily attendance record",
   "s": "A total of 281,223 fans poured through the gates across four matches on June 16, surpassing a mark that had stood since USA '94. More than 1.5 million spectators had attended by mid-tournament, with the USA's opener drawing a record 27.5 million U.S. TV viewers.",
   "src": "FIFA / Yahoo Sports / Goal"
  },
  {
   "cat": "tournament",
   "h": "Scientists warn FIFA that the real heat danger is in the stands",
   "s": "With most host stadiums open-air and afternoon kickoffs played in fierce summer heat, medical experts say moving games to evenings isn't enough — and that older, dehydrated or unacclimatised fans queueing for hours outside are more exposed than the athletes.",
   "src": "The Conversation / Climate Central / AccuWeather"
  },
  {
   "cat": "tournament",
   "h": "FIFA's dynamic ticket prices keep sliding as games sell through",
   "s": "After a backlash over marquee-game fees that topped $6,000, group-stage resale listings have fallen sharply — the cheapest entry dropping from around $184 to $134 between February and May. Critics still argue early-booking international fans were priced out long before the discounts arrived.",
   "src": "Quartz / RTÉ"
  }
 ],
