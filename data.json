 / FourFourTwo / Sky"}, {"cat": "tournament", "h": "Ticket-pricing backlash escalates with formal EU complaint", "s": "Football Supporters Europe and Euroconsumers filed a complaint accusing FIFA of 'abusing its monopoly position' over dynamic pricing, after the body quietly slashed prices and handed back block-booked hotel rooms — yet visible empty seats persist even at marquee fixtures.", "src": "AOL / The Conversation / PBS / RTÉ"}, {"cat": "tournament", "h": "ICE presence and travel restrictions keep unsettling fans", "s": "DHS confirmed immigration agents will work at stadiums in a security role and would not rule out arrests, prompting community groups in Atlanta and Miami to call for an enforcement pause; LA was declared a no-deployment zone, but SoFi stadium workers voted to authorize a strike over pay and ICE fears.", "src": "Al Jazeera / Washington Post / Fox News / American Immigration Council"}], "TOURN": [{"ic": "🏆", "nm": "FIFA World Cup 2026", "sub": "USA · Canada · Mexico", "desc": "Group stage live. 48 teams, first match Jun 11.", "status": "LIVE", "cls": "b-tournament"}, {"ic": "🏟️", "nm": "UEFA Champions League", "sub": "Europe · club", "desc": "2025–26 concluded in late May. New league phase returns September 2026.", "status": "OFF-SEASON", "cls": "b-sched"}, {"flag": "Spain", "nm": "La Liga", "sub": "Spain · domestic", "desc": "2025–26 wrapped up in May. 2026–27 kicks off in August.", "status": "OFF-SEASON", "cls": "b-sched"}, {"flag": "Australia", "nm": "A-League Men", "sub": "Australia · domestic", "desc": "Off-season. 2025–26 finished; new season later in 2026.", "status": "OFF-SEASON", "cls": "b-sched"}], "FIFA": [{"ic": "📋", "nm": "Biggest World Cup yet", "sub": "Format", "desc": "48 teams in 12 groups; top two plus 8 best third-placed sides reach the new Round of 32.", "src": "FIFA / CBS"}, {"ic": "🏟️", "nm": "Club World Cup expanded", "sub": "Club football", "desc": "FIFA's 32-team Club World Cup ran Jun–Jul 2025 in the USA, now a permane